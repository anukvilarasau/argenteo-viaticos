# ── Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Azure AD (para Excel Online via Microsoft Graph) ──
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=tu-client-secret

# ── Excel Online ────────────────────────────────────
# ID del archivo Excel en OneDrive (lo sacás de la URL del archivo)
EXCEL_FILE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nombre de la tabla dentro del Excel (default: Tabla1)
EXCEL_TABLE_NAME=Tabla1
# Solo necesario si el archivo está en un SharePoint/drive específico
# EXCEL_DRIVE_ID=

# ── Servidor ────────────────────────────────────────
PORT=3001
